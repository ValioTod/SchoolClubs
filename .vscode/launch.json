{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "SchoolClubs.Web",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/SchoolClubs.Web/bin/Debug/net8.0/SchoolClubs.Web.dll",
            "args": [],
            "cwd": "${workspaceFolder}/SchoolClubs.Web",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "https://localhost:5001;http://localhost:5000"
            }
        }
    ]
}
