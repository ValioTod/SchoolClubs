@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager

@{
    ViewData["Title"] = "Users Management";
}

<div class="mb-4">
    <h3 class="mb-3">
        <i class="bi bi-people-fill me-2"></i>Users Management
    </h3>
    <p class="text-muted">Manage user roles and view user information</p>
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Joined</th>
                        <th>Current Role</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in ViewBag.Users)
                    {
                        <tr>
                            <td>
                                <a asp-controller="Profile" asp-action="Index" asp-route-id="@user.Id" class="text-decoration-none">
                                    @user.FullName
                                </a>
                            </td>
                            <td><small>@user.Email</small></td>
                            <td><small>@user.DateJoined.ToString("dd.MM.yyyy")</small></td>
                            <td>
                                @{
                                    var rolesDict = (Dictionary<string, List<string>>)ViewBag.UserRoles;
                                    var roles = rolesDict.ContainsKey(user.Id) ? rolesDict[user.Id] : new List<string>();
                                    <span class="badge bg-secondary">@(string.Join(", ", roles))</span>
                                }
                            </td>
                            <td>
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">Change Role</button>
                                    <ul class="dropdown-menu">
                                        <li>
                                            <form asp-action="ChangeUserRole" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="userId" value="@user.Id" />
                                                <input type="hidden" name="role" value="Student" />
                                                <button type="submit" class="dropdown-item">Student</button>
                                            </form>
                                        </li>
                                        <li>
                                            <form asp-action="ChangeUserRole" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="userId" value="@user.Id" />
                                                <input type="hidden" name="role" value="Teacher" />
                                                <button type="submit" class="dropdown-item">Teacher</button>
                                            </form>
                                        </li>
                                        <li>
                                            <form asp-action="ChangeUserRole" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="userId" value="@user.Id" />
                                                <input type="hidden" name="role" value="Admin" />
                                                <button type="submit" class="dropdown-item">Admin</button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="mt-3">
    <a href="@Url.Action("Index")" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
    </a>
</div>
