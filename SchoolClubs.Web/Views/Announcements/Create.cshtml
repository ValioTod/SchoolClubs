@model SchoolClubs.Web.Models.ViewModels.AnnouncementCreateViewModel
@{
    ViewData["Title"] = "Нова обява";
}

<h3>Публикуване на обява</h3>

<div class="row">
    <div class="col-md-8">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ClubId" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Content" class="form-label"></label>
                <textarea asp-for="Content" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Content" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Priority" class="form-label"></label>
                    <select asp-for="Priority" class="form-select"
                            asp-items="Html.GetEnumSelectList<SchoolClubs.Web.Models.AnnouncementPriority>()">
                    </select>
                </div>
                <div class="col-md-6 mb-3 d-flex align-items-end">
                    <div class="form-check">
                        <input asp-for="IsPinned" class="form-check-input" type="checkbox" />
                        <label asp-for="IsPinned" class="form-check-label">Закачи в началото</label>
                    </div>
                </div>
            </div>

            <button type="submit" class="btn btn-info">
                <i class="bi bi-megaphone"></i> <span>Публикувай</span>
            </button>
            <a asp-controller="Clubs" asp-action="Details" asp-route-id="@Model.ClubId" class="btn btn-secondary ms-2">Назад</a>
        </form>
    </div>
</div>
