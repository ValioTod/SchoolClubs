@model SchoolClubs.Web.Controllers.LoginModel

@{
    ViewData["Title"] = "Вход";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <i class="bi bi-mortarboard-fill" style="font-size: 2.5rem; color: #fbbf24;"></i>
                        <h2 class="mt-3 fw-bold">Вход в профил</h2>
                        <p class="text-muted">Влезте в своя профил</p>
                    </div>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger alert-dismissible fade show">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <div>@error.ErrorMessage</div>
                            }
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form method="post" asp-action="Login">
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">Email</label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="потребител@example.com" required>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label">Парола</label>
                            <input asp-for="Password" type="password" class="form-control" placeholder="••••••" required>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="RememberMe" type="checkbox" class="form-check-input" id="rememberMe">
                            <label class="form-check-label" for="rememberMe">Запомни ме</label>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100 mb-3">Вход</button>
                    </form>

                    <hr class="my-3">

                    <div class="text-center">
                        <p class="text-muted mb-2">Нямаш акаунт?
                            <a href="@Url.Action("Register", "Auth")" class="text-primary fw-600">Регистрирай се</a>
                        </p>
                        <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary btn-sm w-100">
                            Обратно към начало
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
