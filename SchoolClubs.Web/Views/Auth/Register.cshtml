@model SchoolClubs.Web.Controllers.RegisterModel

@{
    ViewData["Title"] = "Регистрация";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg">
                <div class="card-body p-5">
                    <div class="text-center mb-5">
                        <i class="bi bi-person-plus-fill" style="font-size: 3rem; color: #fbbf24;"></i>
                        <h2 class="mt-3 fw-bold" data-i18n="auth.register">Регистрация</h2>
                        <p class="text-muted" data-i18n="auth.registerDesc">Присъедини се към SchoolClubs комюнитета</p>
                    </div>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger alert-dismissible fade show">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <div>@error.ErrorMessage</div>
                            }
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form method="post" asp-action="Register">
                        <div class="mb-4">
                            <label asp-for="FullName" class="form-label fw-500" data-i18n="form.fullName">Пълно име</label>
                            <input asp-for="FullName" type="text" class="form-control form-control-lg" placeholder="Иван Петров" required>
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Email" class="form-label fw-500" data-i18n="form.email">Email</label>
                            <input asp-for="Email" type="email" class="form-control form-control-lg" placeholder="user@example.com" required>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Password" class="form-label fw-500" data-i18n="form.password">Парола</label>
                            <input asp-for="Password" type="password" class="form-control form-control-lg" placeholder="••••••" required>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                            <small class="text-muted d-block mt-2" data-i18n="form.passwordHint">Поне 6 символа</small>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ConfirmPassword" class="form-label fw-500" data-i18n="form.confirmPassword">Потвърди парола</label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control form-control-lg" placeholder="••••••" required>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100 fw-600 mb-3" data-i18n="auth.registerBtn">Регистрирай се</button>
                    </form>

                    <hr class="my-4">

                    <div class="text-center">
                        <p class="text-muted mb-0">
                            <span data-i18n="auth.haveAccount">Вече имаш акаунт?</span>
                            <a href="@Url.Action("Login", "Auth")" class="text-primary fw-600" data-i18n="auth.loginLink">Влез</a>
                        </p>
                    </div>

                    <div class="alert alert-info mt-4" role="alert">
                        <small>
                            <i class="bi bi-info-circle me-1"></i>
                            <span data-i18n="auth.termsAgree">Регистрирайки се, приемаш нашите условия за ползване.</span>
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
