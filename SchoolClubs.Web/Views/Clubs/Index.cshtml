@model SchoolClubs.Web.Models.ViewModels.ClubListViewModel
@{
    ViewData["Title"] = "Клубове";
}

<div class="d-flex justify-content-between align-items-center mb-4 reveal">
    <h2><span data-i18n="clubs.title">Клубове</span> <small class="text-muted fs-6">(@Model.TotalCount)</small></h2>
    @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> <span data-i18n="clubs.new">Нов клуб</span>
        </a>
    }
</div>

<form method="get" class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="input-group">
            <input type="text" name="search" value="@Model.SearchQuery" class="form-control" placeholder="Търси клуб..." data-i18n-placeholder="clubs.search" />
            <button class="btn btn-outline-primary" type="submit">
                <i class="bi bi-search"></i>
            </button>
        </div>
    </div>
    <div class="col-md-4">
        <select name="category" class="form-select" onchange="this.form.submit()">
            <option value="Всички" data-i18n="clubs.allcats">Всички категории</option>
            @foreach (var cat in Model.Categories)
            {
                <option value="@cat" selected="@(Model.SelectedCategory == cat)">@cat</option>
            }
        </select>
    </div>
</form>

<div class="row g-4">
    @foreach (var club in Model.Clubs)
    {
        <div class="col-md-4 mb-2 reveal">
            <div class="card club-card h-100 border-0">
                <div class="card-body d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="badge bg-primary">@club.Category</span>
                        @if (!club.IsActive)
                        {
                            <span class="badge bg-danger" data-i18n="clubs.inactive">Неактивен</span>
                        }
                    </div>
                    <h5 class="card-title fw-bold">@club.Name</h5>
                    <p class="card-text text-muted small flex-grow-1">
                        @(club.Description.Length > 100 ? club.Description[..100] + "..." : club.Description)
                    </p>
                    <div class="mt-auto">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <small class="text-muted">
                                <i class="bi bi-people-fill"></i> @club.Members.Count / @club.MaxMembers
                            </small>
                            <a asp-action="Details" asp-route-id="@club.Id" class="btn btn-sm btn-outline-primary" data-i18n="clubs.details">
                                Детайли <i class="bi bi-arrow-right"></i>
                            </a>
                        </div>
                        <div class="member-progress">
                            <div class="member-progress-bar" style="width: @(club.MaxMembers > 0 ? (int)(club.Members.Count * 100.0 / club.MaxMembers) : 0)%"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Clubs.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-emoji-frown display-1 text-muted"></i>
        <p class="text-muted mt-3" data-i18n="clubs.noresults">Няма намерени клубове по зададените критерии.</p>
    </div>
}
