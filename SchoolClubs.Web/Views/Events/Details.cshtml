@model SchoolClubs.Web.Models.ViewModels.EventDetailsViewModel
@{
    ViewData["Title"] = Model.Event.Title;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index" data-i18n="events.title">Събития</a></li>
        <li class="breadcrumb-item active">@Model.Event.Title</li>
    </ol>
</nav>

<div class="row">
    <div class="col-lg-8">
        <h2>@Model.Event.Title</h2>
        <span class="badge bg-primary mb-3">@Model.Event.Club.Name</span>

        @if (Model.Event.IsCancelled)
        {
            <div class="alert alert-danger"><i class="bi bi-x-circle"></i> <span data-i18n="events.cancelled">Това събитие е отменено.</span></div>
        }

        <div class="card mb-4">
            <div class="card-body">
                @if (Model.Event.Description != null)
                {
                    <p>@Model.Event.Description</p>
                }

                <div class="row">
                    <div class="col-md-6">
                        <p><i class="bi bi-calendar"></i> <strong data-i18n="events.start">Начало:</strong> @Model.Event.StartDate.ToString("dd.MM.yyyy HH:mm")</p>
                        @if (Model.Event.EndDate != null)
                        {
                            <p><i class="bi bi-calendar-check"></i> <strong data-i18n="events.end">Край:</strong> @Model.Event.EndDate.Value.ToString("dd.MM.yyyy HH:mm")</p>
                        }
                    </div>
                    <div class="col-md-6">
                        @if (Model.Event.Location != null)
                        {
                            <p><i class="bi bi-geo-alt"></i> <strong data-i18n="events.location">Място:</strong> @Model.Event.Location</p>
                        }
                        <p>
                            <i class="bi bi-people"></i> <strong data-i18n="events.signedup">Записани:</strong> @Model.AttendeeCount
                            @if (Model.Event.MaxAttendees > 0)
                            {
                                <span>/ @Model.Event.MaxAttendees</span>
                            }
                        </p>
                    </div>
                </div>
            </div>
        </div>

        @if (User.Identity?.IsAuthenticated == true && !Model.Event.IsCancelled)
        {
            <div class="mb-4">
                @if (!Model.IsSignedUp && Model.CanSignUp)
                {
                    <form asp-action="SignUp" asp-route-id="@Model.Event.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle"></i> <span data-i18n="events.signup">Запиши се</span>
                        </button>
                    </form>
                }
                else if (Model.IsSignedUp && !Model.HasAttended)
                {
                    <span class="badge bg-success fs-6 me-2" data-i18n="events.registered">Записан/а</span>
                    <form asp-action="CancelSignUp" asp-route-id="@Model.Event.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger btn-sm" data-i18n="events.cancelreg">Отказ</button>
                    </form>
                }
                @if (Model.HasAttended)
                {
                    <span class="badge bg-info fs-6"><i class="bi bi-patch-check"></i> <span data-i18n="events.attended">Присъствал/а</span></span>
                }
            </div>

            @if (Model.IsSignedUp && !Model.HasAttended && Model.Event.AttendanceCode != null)
            {
                <div class="card mb-4">
                    <div class="card-body">
                        <h6 data-i18n="events.checkin">Отбележи присъствие с код</h6>
                        <form asp-action="CheckIn" asp-route-id="@Model.Event.Id" method="post" class="input-group">
                            @Html.AntiForgeryToken()
                            <input type="text" name="code" class="form-control" placeholder="Въведи кода..." data-i18n-placeholder="events.entercode" maxlength="8" required />
                            <button type="submit" class="btn btn-info">
                                <i class="bi bi-qr-code"></i> Потвърди
                            </button>
                        </form>
                    </div>
                </div>
            }

            @if (Model.IsClubMember && (Model.Event.Club.LeaderId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value || User.IsInRole("Admin")))
            {
                <div class="mb-4">
                    @if (!Model.Event.IsCancelled)
                    {
                        <form asp-action="CancelEvent" asp-route-id="@Model.Event.Id" method="post" class="d-inline" onsubmit="return confirm('Cancel this event?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger">
                                <i class="bi bi-x-circle"></i> <span data-i18n="events.cancelevent">Cancel Event</span>
                            </button>
                        </form>
                    }
                    else
                    {
                        <form asp-action="RestoreEvent" asp-route-id="@Model.Event.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-success">
                                <i class="bi bi-arrow-counterclockwise"></i> <span data-i18n="events.restoreevent">Restore Event</span>
                            </button>
                        </form>
                    }
                </div>
            }
        }
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-people"></i> <span data-i18n="events.attendees">Записани участници</span>
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                    @foreach (var att in Model.Event.Attendees)
                    {
                        <li class="list-group-item d-flex justify-content-between">
                            <span>@att.User.FullName</span>
                            @if (att.HasAttended)
                            {
                                <span class="badge bg-success" data-i18n="events.attendedshort">Присъствал</span>
                            }
                        </li>
                    }
                </ul>
                @if (!Model.Event.Attendees.Any())
                {
                    <div class="text-center py-3 text-muted" data-i18n="events.nosignups">Все още няма записани.</div>
                }
            </div>
        </div>
    </div>
</div>
