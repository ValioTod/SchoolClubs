@{
    ViewData["Title"] = "Предимства на членството";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="fw-bold mb-3">Защо да се присъедините към клуб?</h1>
        <p class="text-muted fs-5">Членството дава достъп до експропоспективни възможности и комюнитет</p>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-6">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="mb-3">
                        <i class="bi bi-people-fill" style="font-size:2rem;color:#4f46e5"></i>
                    </div>
                    <h5 class="card-title fw-bold">Гостински достъп</h5>
                    <ul class="list-unstyled small text-muted">
                        <li><i class="bi bi-check-circle me-2"></i>Разглеждане на всички клубове</li>
                        <li><i class="bi bi-check-circle me-2"></i>Четене на описания и графици</li>
                        <li><i class="bi bi-check-circle me-2"></i>Преглед на членове</li>
                        <li><i class="bi bi-check-circle me-2"></i>Разглеждане на публични събития</li>
                        <li><i class="bi bi-check-circle me-2"></i>Четене на последни обяви</li>
                        <li><i class="bi bi-x-circle me-2" style="color:#ef4444"></i>Присъединяване към события</li>
                        <li><i class="bi bi-x-circle me-2" style="color:#ef4444"></i>Публикуване на съдържание</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card h-100 border-0 shadow-sm border-primary border-2">
                <div class="card-body">
                    <div class="mb-3">
                        <i class="bi bi-star-fill" style="font-size:2rem;color:#fbbf24"></i>
                    </div>
                    <h5 class="card-title fw-bold">Членски предимства</h5>
                    <ul class="list-unstyled small text-muted">
                        <li><i class="bi bi-check-circle me-2" style="color:#10b981"></i>Всичко от гостински достъп, плюс:</li>
                        <li><i class="bi bi-check-circle me-2" style="color:#10b981"></i>Запись в събития на клуба</li>
                        <li><i class="bi bi-check-circle me-2" style="color:#10b981"></i>Получаване на уведомления</li>
                        <li><i class="bi bi-check-circle me-2" style="color:#10b981"></i>Качване на снимки в галерия</li>
                        <li><i class="bi bi-check-circle me-2" style="color:#10b981"></i>Получаване и публикуване на отзиви</li>
                        <li><i class="bi bi-check-circle me-2" style="color:#10b981"></i>Събиране на точки и достижения</li>
                        <li><i class="bi bi-check-circle me-2" style="color:#10b981"></i>Участие в класирането</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card border-0 text-center h-100 shadow-sm">
                <div class="card-body">
                    <i class="bi bi-award-fill" style="font-size:2.5rem;color:#06b6d4"></i>
                    <h6 class="mt-3 fw-bold">Достижения</h6>
                    <p class="text-muted small">Разблокирай специални значки като достигаш различни вех в своята активност</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 text-center h-100 shadow-sm">
                <div class="card-body">
                    <i class="bi bi-graph-up-arrow" style="font-size:2.5rem;color:#10b981"></i>
                    <h6 class="mt-3 fw-bold">Класация</h6>
                    <p class="text-muted small">Се състезавай с други ученици за места в класирането чрез събиране на точки</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 text-center h-100 shadow-sm">
                <div class="card-body">
                    <i class="bi bi-people-fill" style="font-size:2.5rem;color:#f59e0b"></i>
                    <h6 class="mt-3 fw-bold">Комюнитет</h6>
                    <p class="text-muted small">Свързвай се с еднопосочни ученици, правете приятелства и споделяйте интереси</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-5">
        <div class="col-md-8 mx-auto">
            <div class="alert alert-info border-0">
                <div class="mb-3">
                    <strong>Готов ли си да се присъедините?</strong>
                </div>
                <p class="mb-2">Регистрирайте се сега и начнете вашето приключение с школските клубове!</p>
                @if (User.Identity?.IsAuthenticated ?? false)
                {
                    <a href="@Url.Action("Index", "Clubs")" class="btn btn-primary btn-sm">
                        <i class="bi bi-collection me-1"></i> Преглед на клубове
                    </a>
                }
                else
                {
                    <a href="@Url.Action("Register", "Auth")" class="btn btn-primary btn-sm">
                        <i class="bi bi-person-plus-fill me-1"></i> Регистрирай се
                    </a>
                    <a href="@Url.Action("Login", "Auth")" class="btn btn-outline-primary btn-sm ms-2">
                        <i class="bi bi-box-arrow-in-right me-1"></i> Вход
                    </a>
                }
            </div>
        </div>
    </div>
</div>
