@model SchoolClubs.Web.Models.ViewModels.ProfileEditViewModel
@{
    ViewData["Title"] = "Редактирай профил";
}

<h3><i class="bi bi-pencil-square"></i> Редактирай профила</h3>

<div class="row">
    <div class="col-md-8">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="text-center mb-4">
                @if (Model.CurrentProfilePicture != null)
                {
                    <img src="@Model.CurrentProfilePicture" class="rounded-circle mb-2" width="100" height="100" style="object-fit:cover" />
                }
                else
                {
                    <div class="rounded-circle bg-primary d-inline-flex align-items-center justify-content-center mb-2" style="width:100px;height:100px">
                        <span class="text-white display-5">@Model.FullName[0]</span>
                    </div>
                }
            </div>

            <div class="mb-3">
                <label asp-for="FullName" class="form-label"></label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Grade" class="form-label"></label>
                    <input asp-for="Grade" class="form-control" type="number" min="1" max="12" />
                    <span asp-validation-for="Grade" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="GradeSection" class="form-label"></label>
                    <input asp-for="GradeSection" class="form-control" />
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Bio" class="form-label"></label>
                <textarea asp-for="Bio" class="form-control" rows="3" maxlength="500"></textarea>
                <small class="text-muted">Максимум 500 символа</small>
            </div>

            <div class="mb-3">
                <label class="form-label">Профилна снимка</label>
                <input type="file" name="profilePicture" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
                <small class="text-muted">Макс. 2MB. JPG, PNG или WebP.</small>
            </div>

            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg"></i> Запази
            </button>
            <a asp-action="Index" class="btn btn-secondary ms-2">Отказ</a>
        </form>
    </div>
</div>
