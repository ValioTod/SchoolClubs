@model SchoolClubs.Web.Models.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = Model.User.FullName;
}

<div class="row">
    <div class="col-md-4 text-center mb-4">
        <div class="card">
            <div class="card-body">
                <div class="mb-3">
                    @if (Model.User.ProfilePicturePath != null)
                    {
                        <img src="@Model.User.ProfilePicturePath" class="rounded-circle" width="120" height="120" style="object-fit:cover" />
                    }
                    else
                    {
                        <div class="rounded-circle bg-primary d-inline-flex align-items-center justify-content-center" style="width:120px;height:120px">
                            <span class="text-white display-4">@Model.User.FullName[0]</span>
                        </div>
                    }
                </div>
                <h4>@Model.User.FullName</h4>
                @if (Model.User.Grade > 0)
                {
                    <p class="text-muted">@Model.User.Grade @Model.User.GradeSection клас</p>
                }
                @if (Model.User.Bio != null)
                {
                    <p>@Model.User.Bio</p>
                }

                @if (Model.IsOwnProfile)
                {
                    <a asp-action="Edit" class="btn btn-outline-primary btn-sm mt-2">
                        <i class="bi bi-pencil"></i> <span data-i18n="profile.edit">Edit Profile</span>
                    </a>
                }

                <div class="row text-center mt-3">
                    <div class="col-4">
                        <h5>@Model.TotalPoints</h5>
                        <small class="text-muted" data-i18n="profile.points">Точки</small>
                    </div>
                    <div class="col-4">
                        <h5>#@Model.Rank</h5>
                        <small class="text-muted" data-i18n="profile.rank">Ранг</small>
                    </div>
                    <div class="col-4">
                        <h5>@Model.EventsAttendedCount</h5>
                        <small class="text-muted" data-i18n="profile.events">Събития</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <h4 class="mb-3" data-i18n="profile.memberships">Членства в клубове</h4>
        @if (Model.Memberships.Any())
        {
            <div class="row mb-4">
                @foreach (var m in Model.Memberships)
                {
                    <div class="col-md-6 mb-2">
                        <div class="card">
                            <div class="card-body py-2">
                                <a asp-controller="Clubs" asp-action="Details" asp-route-id="@m.ClubId" class="text-decoration-none">
                                    <strong>@m.Club.Name</strong>
                                </a>
                                <br />
                                <small class="text-muted">
                                    @switch (m.Role)
                                    {
                                        case SchoolClubs.Web.Models.MemberRole.President:
                                            <span class="badge bg-warning text-dark" data-i18n="clubs.president">Председател</span>
                                            break;
                                        case SchoolClubs.Web.Models.MemberRole.Moderator:
                                            <span class="badge bg-info" data-i18n="clubs.moderator">Модератор</span>
                                            break;
                                        default:
                                            <span class="badge bg-light text-dark" data-i18n="profile.member">Член</span>
                                            break;
                                    }
                                    от @m.JoinedOn.ToString("dd.MM.yyyy")
                                </small>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-muted" data-i18n="profile.nomember">Не е член на нито един клуб.</p>
        }

        <h4 class="mb-3" data-i18n="profile.awards">Награди</h4>
        @if (Model.Achievements.Any())
        {
            <div class="row">
                @foreach (var ua in Model.Achievements)
                {
                    <div class="col-md-4 mb-3">
                        <div class="card text-center achievement-card">
                            <div class="card-body">
                                <i class="bi bi-award-fill text-warning display-6"></i>
                                <h6 class="mt-2">@ua.Achievement.Name</h6>
                                <small class="text-muted">@ua.Achievement.Description</small>
                                <br />
                                <span class="badge bg-primary mt-1">+@ua.Achievement.PointsAwarded т.</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-muted" data-i18n="profile.noawards">Все още няма спечелени награди.</p>
        }
    </div>
</div>
