<!DOCTYPE html>
<html lang="bg" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="SchoolClubs — Платформа за управление на училищни клубове" />
    <title>@ViewData["Title"] - Училищни клубове</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <!-- Page loader -->
    <div id="pageLoader">
        <div class="loader-spinner"></div>
    </div>

    <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">
                <i class="bi bi-mortarboard-fill me-2"></i><span data-i18n="nav.brand">Училищни клубове</span>
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Clubs" asp-action="Index"><i class="bi bi-collection me-1"></i><span data-i18n="nav.clubs">Клубове</span></a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Events" asp-action="Index"><i class="bi bi-calendar-event me-1"></i><span data-i18n="nav.events">Събития</span></a>
                    </li>
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Profile" asp-action="Leaderboard"><i class="bi bi-trophy me-1"></i><span data-i18n="nav.leaderboard">Класация</span></a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Feedback" asp-action="Index"><i class="bi bi-chat-dots me-1"></i><span data-i18n="nav.feedback">Обратна връзка</span></a>
                        </li>
                    }
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="Index" style="color:#fbbf24 !important">
                                <i class="bi bi-shield-lock-fill"></i> <span data-i18n="nav.admin">Админ</span>
                            </a>
                        </li>
                    }
                </ul>
                <ul class="navbar-nav align-items-center">
                    <li class="nav-item me-1">
                        <button id="themeSwitcher" class="toggle-btn" title="Toggle dark/light theme">
                            <i class="bi bi-moon-stars-fill"></i>
                        </button>
                    </li>
                    <li class="nav-item me-2">
                        <button id="langSwitcher" class="toggle-btn" title="Switch language">
                            <span id="langLabel">EN</span>
                        </button>
                    </li>
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Profile" asp-action="Index">
                                <i class="bi bi-person-circle"></i> <span data-i18n="nav.profile">Профил</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="d-inline">
                                <button type="submit" class="nav-link btn btn-link" data-i18n="nav.logout">Изход</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Auth" asp-action="Login" data-i18n="nav.login">Вход</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link btn btn-sm btn-outline-light ms-2 px-3" asp-controller="Auth" asp-action="Register" data-i18n="nav.register">Регистрация</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main class="container py-4">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="py-5 mt-auto">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-3">
                    <h5 class="fw-bold mb-3"><i class="bi bi-mortarboard-fill me-2" style="color:#fbbf24"></i><span data-i18n="nav.brand">Училищни клубове</span></h5>
                    <p class="small text-muted mb-0" data-i18n="footer.desc">Платформа за управление на училищни клубове, събития и постижения. Дипломен проект.</p>
                </div>
                <div class="col-md-4 mb-3">
                    <h6 class="fw-bold mb-3" data-i18n="footer.links">Навигация</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><a href="/" class="text-decoration-none text-muted"><i class="bi bi-house me-1"></i> <span data-i18n="footer.home">Начало</span></a></li>
                        <li class="mb-2"><a asp-controller="Clubs" asp-action="Index" class="text-decoration-none text-muted"><i class="bi bi-collection me-1"></i> <span data-i18n="nav.clubs">Клубове</span></a></li>
                        <li class="mb-2"><a asp-controller="Events" asp-action="Index" class="text-decoration-none text-muted"><i class="bi bi-calendar-event me-1"></i> <span data-i18n="nav.events">Събития</span></a></li>
                    </ul>
                </div>
                <div class="col-md-4 mb-3">
                    <h6 class="fw-bold mb-3" data-i18n="footer.contact">Контакти</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><i class="bi bi-envelope me-2"></i><span data-i18n="footer.email">Email: support@schoolclubs.edu</span></li>
                        <li class="mb-2"><i class="bi bi-telephone me-2"></i><span data-i18n="footer.phone">Телефон: +359 (0) 2 XXX XXXX</span></li>
                        <li class="mb-2"><i class="bi bi-geo-alt me-2"></i><span data-i18n="footer.location">Място: България</span></li>
                    </ul>
                </div>
            </div>
            <hr style="border-color: rgba(255,255,255,0.1)" />
            <p class="text-center small text-muted mb-0" data-i18n="footer.copy">&copy; @DateTime.Now.Year Училищни клубове. Дипломен проект.</p>
        </div>
    </footer>

    <!-- Back to top -->
    <button id="backToTop" title="Back to top"><i class="bi bi-chevron-up"></i></button>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
